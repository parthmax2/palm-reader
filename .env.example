# Copy to .env and fill in. Never commit .env.

# Google Gemini API key (from Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Model used for reading generation
GEMINI_MODEL=gemini-2.5-flash

# Thinking budget for Gemini 2.5 (0 = fastest/cheapest, higher = more reasoning)
GEMINI_THINKING_BUDGET=0

# Generation temperature (0.0-1.0); ~0.6 = warm but consistent
GEMINI_TEMPERATURE=0.6

# If true, uploaded palm images are deleted immediately after processing
DELETE_IMAGES_AFTER_PROCESSING=true
